<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.DatePicker?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.Pane?>
<?import javafx.scene.text.Font?>

<AnchorPane prefHeight="947.0" prefWidth="917.0" xmlns="http://javafx.com/javafx/26" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="selambusreservationsystem.UIController">
    <children>
        <ImageView fx:id="img" fitHeight="608.0" fitWidth="856.0" layoutX="28.0" layoutY="28.0" pickOnBounds="true"
                   preserveRatio="true">
            <image>
                <Image url="@resources/bus.png"/>
            </image>
        </ImageView>
        <Button fx:id="btnAdmin" layoutX="20.0" layoutY="20.0" onAction="#openAdminPanel" prefHeight="25.0"
                prefWidth="70.0" style="-fx-background-color: #e74c3c; -fx-text-fill: white; -fx-font-size: 10;"
                text="Admin"/>
        <Pane blendMode="SRC_ATOP" layoutX="467.0" layoutY="191.0" prefHeight="281.0" prefWidth="385.0"
              style="               -fx-background-color:               rgba(255,255,255,0.7);               -fx-border-color: #2c3e50;               -fx-border-radius: 10;               -fx-background-radius: 10;">
            <children>
                <Label fx:id="lblSearch" alignment="CENTER" layoutX="-1.0" layoutY="50.0" prefHeight="23.0"
                       prefWidth="385.0" text="Search" textAlignment="CENTER">
                    <font>
                        <Font name="System Bold" size="20.0"/>
                    </font>
                </Label>
                <DatePicker fx:id="datePicker" layoutX="87.0" layoutY="159.0" onAction="#getDate" prefHeight="38.0"
                            prefWidth="211.0" promptText="Departure date"/>
                <Button fx:id="btnSearch" layoutX="282.0" layoutY="221.0" mnemonicParsing="false"
                        onAction="#searchButton" prefHeight="32.0" prefWidth="76.0" text="Search"/>
                <ComboBox fx:id="from" layoutX="20.0" layoutY="105.0" prefWidth="150.0" promptText="Origin"
                          style=" -fx-background-radius: 10; -fx-border-radius: 10; -fx-padding: 5; "/>
                <ComboBox fx:id="to" layoutX="223.0" layoutY="105.0" prefWidth="150.0" promptText="Destination"
                          style=" -fx-background-radius: 10; -fx-border-radius: 10; -fx-padding: 5; "/>
            </children>
        </Pane>
        <TableView fx:id="tripTable" layoutX="36.0" layoutY="656.0" prefHeight="250.0" prefWidth="840.0">

            <columns>

                <TableColumn fx:id="colOrigin" prefWidth="120" text="From"/>
                <TableColumn fx:id="colDestination" prefWidth="120" text="To"/>
                <TableColumn fx:id="colDate" prefWidth="120" text="Date"/>
                <TableColumn fx:id="colTime" prefWidth="120" text="Time"/>
                <TableColumn fx:id="colPrice" prefWidth="100" text="Price"/>
                <TableColumn fx:id="colBus" prefWidth="120" text="Bus"/>
                <TableColumn fx:id="colAction" text="Action"/>

            </columns>

        </TableView>
    </children>
</AnchorPane>
